    "intensity_scale_trainable": true,
    "num_datasets": 4,
    "object_big": true,
    "probe_big": true,
    "batch_norm": false,
    "loss_function": "Poisson",
    "amp_activation": "silu",
    "amp_loss": null,
    "amp_loss_coeff": 4.0,
    "phase_loss": null,
    "phase_loss_coeff": 1.0,
    "amplitude_variance_loss": true,
