    "batch_size": 400
  },
  "datagen_config": {
    "object_class": "dead_leaves_reim_gmm",
    "objects_per_probe": 4,
    "gmm_n_clusters": "auto",
    "perturbation_mode": "physical",
    "phase_jitter_std": 0.1,
    "amplitude_scale_std": 0.03
